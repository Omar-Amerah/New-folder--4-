{
  "name": "modular-fleet-arena",
  "version": "1.0.0",
  "description": "Browser multiplayer modular space fleet arena.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "node netlify-build.js",
    "check": "npm run build && npm run test:architecture && npm run test:module-imports && node --check server.js && node --check netlify-build.js && node --check tools/run-tests.js && node --check verify-runtime.js && node --check verify-canvas-removal.js && node --check verify-pixi-lifecycle.js && node --check verify-turret-render.js && node --check verify-pixi-browser-support.js && node --check verify-match-start-render.js && node --check verify-blueprint-mobile-scroll.js && node verify-canvas-removal.js",
    "test:unit": "node tools/run-tests.js unit",
    "test:integration": "npm run build && node tools/run-tests.js integration",
    "test:protocol": "node tools/run-tests.js protocol",
    "test:smoke": "node tools/run-tests.js protocol",
    "test:browser": "npm run build && node tools/run-tests.js browser",
    "test:all": "npm run check && node tools/run-tests.js all",
    "verify": "npm run test:all",
    "test:canvas-removal": "node verify-canvas-removal.js",
    "test:pixi-lifecycle": "node verify-pixi-lifecycle.js",
    "test:pixi-browser": "node verify-turret-render.js && node verify-pixi-lifecycle.js",
    "test:turrets": "node verify-turrets.js",
    "test:turret-render": "node verify-turret-render.js",
    "test:live-turrets": "node verify-live-turrets.js",
    "test:heat": "node verify-heat.js",
    "test:engine-exhaust": "node verify-engine-exhaust.js",
    "test:movement": "node verify-movement.js",
    "test:targeting": "node verify-targeting.js",
    "test:reconnect": "node verify-reconnect.js && node verify-lobby-refresh-reconnect.js",
    "test:core-reactor": "node verify-core-reactor.js",
    "test:heat-thermo": "node verify-heat-thermo.js",
    "test:repair-target": "node verify-repair-target.js",
    "test:combat-review": "node verify-combat-review.js",
    "test:heat-effects": "node verify-heat-effects.js",
    "test:match-start-render": "node verify-match-start-render.js",
    "test:architecture": "node verify-module-boundaries.js",
    "test:module-imports": "node verify-module-imports.js",
    "test:shared-parity": "node verify-shared-parity.js",
    "test:snapshot-merge": "node verify-snapshot-merge.js",
    "test:production-path": "node verify-production-path.js"
  },
  "keywords": [
    "browser-game",
    "multiplayer",
    "websocket",
    "space",
    "rts"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.2",
    "pixi.js": "^8.19.0"
  },
  "devDependencies": {
    "playwright": "^1.61.1"
  }
}
