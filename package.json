{
  "name": "modular-fleet-arena",
  "version": "1.0.0",
  "description": "Browser multiplayer modular space fleet arena.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "node netlify-build.js",
    "check": "npm run build && npm run test:architecture && npm run test:module-imports && npm run check:components && npm run test:component-catalogue && node --check server.js && node --check netlify-build.js && node --check tools/run-tests.js && node --check verify-runtime.js && node --check verify-canvas-removal.js && node --check verify-pixi-lifecycle.js && node --check verify-turret-render.js && node --check verify-pixi-browser-support.js && node --check verify-match-start-render.js && node --check verify-blueprint-mobile-scroll.js && node verify-canvas-removal.js && node verify-economy.js",
    "test:unit": "node tools/run-tests.js unit",
    "test:integration": "npm run build && node tools/run-tests.js integration",
    "test:protocol": "node tools/run-tests.js protocol",
    "test:smoke": "node tools/run-tests.js smoke",
    "test:browser": "npm run build && node tools/run-tests.js browser",
    "test:all": "npm run check && node tools/run-tests.js all && npm run test:snapshot-contract && npm run test:snapshot-resync && npm run test:network-backpressure && npm run test:network-soak",
    "verify": "npm run test:all",
    "test:canvas-removal": "node verify-canvas-removal.js",
    "test:pixi-lifecycle": "node verify-pixi-lifecycle.js",
    "test:pixi-browser": "node verify-turret-render.js && node verify-pixi-lifecycle.js",
    "test:turrets": "node verify-turrets.js",
    "test:turret-render": "node verify-turret-render.js",
    "test:live-turrets": "node verify-live-turrets.js",
    "test:heat": "node verify-heat.js",
    "test:engine-exhaust": "node verify-engine-exhaust.js",
    "test:movement": "node verify-movement.js",
    "test:targeting": "node verify-targeting.js",
    "test:reconnect": "node verify-reconnect.js && node verify-lobby-refresh-reconnect.js",
    "test:core-reactor": "node verify-core-reactor.js",
    "test:heat-thermo": "node verify-heat-thermo.js",
    "test:repair-target": "node verify-repair-target.js",
    "test:combat-review": "node verify-combat-review.js",
    "test:heat-effects": "node verify-heat-effects.js",
    "test:match-start-render": "node verify-match-start-render.js",
    "test:architecture": "node verify-module-boundaries.js",
    "test:module-imports": "node verify-module-imports.js",
    "test:shared-parity": "node verify-shared-parity.js",
    "test:snapshot-merge": "node verify-snapshot-merge.js",
    "test:production-path": "node verify-production-path.js",
    "check:components": "node verify-components.js",
    "test:components": "node verify-components.js",
    "test:component-catalogue": "node verify-component-catalogue.js",
    "test:maps": "node verify-maps-objectives.js",
    "test:map-invariants": "node verify-maps-objectives.js",
    "test:objectives": "node verify-maps-objectives.js",
    "test:scoring": "node verify-maps-objectives.js",
    "test:match-progression": "node verify-maps-objectives.js",
    "test:economy": "node verify-economy.js",
    "test:combat": "node verify-combat-determinism.js && node verify-combat-review.js && node verify-combat-catchup.js",
    "test:projectiles": "node verify-combat-catchup.js",
    "test:point-defense": "node verify-combat-catchup.js",
    "test:support": "node verify-repair-target.js && node verify-combat-review.js && node verify-combat-catchup.js",
    "test:combat-soak": "npm run test:soak",
    "test:combat-protocol": "node tools/run-tests.js protocol",
    "test:blueprint-storage": "node verify-blueprint-storage.js",
    "test:blueprint-parity": "node verify-blueprint-parity.js",
    "test:component-indexes": "node verify-component-indexes.js",
    "test:lifecycle": "node verify-lifecycle.js",
    "test:spawn-planner": "node verify-spawn-planner.js",
    "test:selection": "node verify-selection.js",
    "test:economy-sequence": "node verify-economy-sequence.js",
    "test:bots": "node verify-bots.js",
    "test:soak": "node tools/run-tests.js soak",
    "test:thermal-topology": "node verify-thermal-topology.js",
    "test:heat-transfer": "node verify-heat-transfer.js",
    "test:heat-cooling": "node verify-heat-cooling.js",
    "test:power": "node verify-power.js",
    "test:component-health": "node verify-component-health.js",
    "test:meltdown": "node verify-meltdown.js",
    "test:heat-protocol": "node verify-heat-protocol.js",
    "test:heat-browser": "npm run build && node verify-heat-browser.js",
    "test:heat-soak": "node verify-heat-soak.js",
    "test:websocket-frames": "node verify-websocket-frames.js",
    "test:protocol-schema": "node verify-protocol-schema.js",
    "test:network-connections": "node verify-network-connections.js",
    "test:network-protocol": "node verify-network-protocol.js",
    "test:network-browser": "npm run build && node verify-network-browser.js",
    "test:snapshot-contract": "node verify-snapshot-contract.js",
    "test:snapshot-resync": "node verify-snapshot-resync.js",
    "test:network-backpressure": "node verify-network-backpressure.js",
    "test:network-soak": "node verify-network-soak.js",
    "test:messagepack-codec": "node verify-network-protocol.js --codec-only"
  },
  "keywords": [
    "browser-game",
    "multiplayer",
    "websocket",
    "space",
    "rts"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.2",
    "pixi.js": "^8.19.0"
  },
  "devDependencies": {
    "playwright": "^1.61.1"
  }
}
